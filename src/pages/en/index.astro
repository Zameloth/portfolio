---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import Hero from '../../components/Hero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { skillCategories } from '../../data/skills';
import { translations } from '../../i18n/translations';

const t = translations.en;

const projects = (await getCollection('projects', ({ id }) => id.startsWith('en/')))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={t.siteTitle} description={t.siteDescription} locale="en" canonicalPath="/">
	<Hero
		name="Théo ELOY"
		headline={t.heroHeadline}
		description={t.heroDescription}
		availability={t.heroAvailability}
		cvHref="/cv-theo-eloy-en.pdf"
	/>

	<section id="about" class="max-w-4xl mx-auto px-6 py-20 border-t border-slate-800">
		<h2 data-reveal class="text-2xl font-bold font-mono mb-10 uppercase tracking-widest">
			<span class="text-amber-400">// </span>{t.sectionAbout}
		</h2>
		<p data-reveal class="text-slate-400 mb-10 leading-relaxed">{t.aboutIntro}</p>
		<div class="flex flex-col gap-10">
			<div data-reveal>
				<h3 class="text-sm font-mono text-amber-400 uppercase tracking-widest mb-5">{t.aboutExperience}</h3>
				<div class="grid gap-6 sm:grid-cols-2">
					{t.experience.map((item) => (
						<div class="border-l-2 border-slate-700 pl-4">
							<p class="font-mono text-slate-100 text-sm font-semibold">{item.role}</p>
							<p class="text-xs font-mono text-slate-500 mt-0.5">{item.company}</p>
							<p class="text-xs font-mono text-amber-500/70 mt-0.5 mb-2">{item.period}</p>
							<ul class="flex flex-col gap-1">
								{item.bullets.map((bullet) => (
									<li class="text-xs text-slate-400 flex gap-2">
										<span class="text-amber-500/60 shrink-0">›</span>
										<span>{bullet}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</div>
			<div data-reveal style="transition-delay: 80ms">
				<h3 class="text-sm font-mono text-amber-400 uppercase tracking-widest mb-5">{t.aboutEducation}</h3>
				<div class="grid gap-5 sm:grid-cols-3">
					{t.education.map((item) => (
						<div class="border-l-2 border-slate-700 pl-4">
							<p class="font-mono text-slate-100 text-sm font-semibold">{item.degree}</p>
							<p class="text-xs font-mono text-slate-500 mt-0.5">{item.school}</p>
							<p class="text-xs font-mono text-amber-500/70 mt-0.5">{item.period}</p>
							{item.note && (
								<p class="text-xs text-slate-500 mt-1 italic">{item.note}</p>
							)}
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="projects" class="max-w-4xl mx-auto px-6 py-20 border-t border-slate-800">
		<h2 data-reveal class="text-2xl font-bold font-mono mb-10 uppercase tracking-widest">
			<span class="text-amber-400">// </span>{t.sectionProjects}
		</h2>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{projects.map((project, i) => {
				const slug = project.id.replace(/^en\//, '').replace(/\.md$/, '');
				return (
					<div data-reveal style={`transition-delay: ${i * 80}ms`}>
						<ProjectCard
							href={`/en/projects/${slug}`}
							title={project.data.title}
							description={project.data.description}
							stack={project.data.stack}
							repo={project.data.repo}
							demo={project.data.demo}
							readMoreLabel={t.readMore}
						/>
					</div>
				);
			})}
		</div>
	</section>

	<section id="skills" class="max-w-4xl mx-auto px-6 py-20 border-t border-slate-800">
		<h2 data-reveal class="text-2xl font-bold font-mono mb-10 uppercase tracking-widest">
			<span class="text-amber-400">// </span>{t.sectionSkills}
		</h2>
		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
			{skillCategories.map((category, i) => (
				<div data-reveal style={`transition-delay: ${i * 80}ms`}>
					<h3 class="text-sm font-mono text-amber-400 uppercase tracking-widest mb-3">
						{t.skillCategoryNames[category.key]}
					</h3>
					<div class="flex flex-wrap gap-2">
						{category.skills.map((skill) => (
							<span class={`px-2 py-1 text-sm font-mono rounded border transition-colors cursor-default ${skill.level === 'core' ? 'bg-amber-500/10 text-amber-300 border-amber-500/40 hover:border-amber-400 hover:text-amber-200' : 'bg-slate-800/60 text-slate-400 border-slate-700 hover:border-slate-500 hover:text-slate-200'}`}>
								{skill.name}
							</span>
						))}
					</div>
				</div>
			))}
		</div>
	</section>

	<section id="contact" class="max-w-4xl mx-auto px-6 py-20 border-t border-slate-800">
		<h2 data-reveal class="text-2xl font-bold font-mono mb-6 uppercase tracking-widest">
			<span class="text-amber-400">// </span>{t.sectionContact}
		</h2>
		<p data-reveal class="text-slate-400 mb-8">{t.contactIntro}</p>
		<div data-reveal class="flex flex-col sm:flex-row gap-4">
			<a
				href="mailto:theoeloy12@gmail.com"
				class="inline-flex items-center gap-2 px-4 py-2 font-mono text-sm border border-amber-500 text-amber-400 hover:border-amber-400 hover:text-amber-300 transition-colors rounded"
			>
				theoeloy12@gmail.com
			</a>
			<a
				href="https://github.com/TheoEloy"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 px-4 py-2 font-mono text-sm border border-slate-600 text-slate-300 hover:border-slate-400 hover:text-white transition-colors rounded"
			>
				GitHub
			</a>
			<a
				href="https://linkedin.com/in/theo-eloy"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 px-4 py-2 font-mono text-sm border border-slate-600 text-slate-300 hover:border-slate-400 hover:text-white transition-colors rounded"
			>
				LinkedIn
			</a>
		</div>
	</section>
</Layout>

<script>
	document.documentElement.classList.add('js-reveal');

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('revealed');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.12 }
	);

	document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>
