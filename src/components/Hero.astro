---
interface Props {
	name: string;
	headline: string;
	description?: string;
}

const { name, headline, description } = Astro.props;
---

<section class="max-w-4xl mx-auto px-6 py-20 flex items-center justify-center min-h-[calc(100vh-180px)]">
	<div class="text-center">
		<h1 class="text-5xl md:text-6xl font-mono font-bold mb-4 text-slate-50">
			{name}
		</h1>
		<p class="text-xl md:text-2xl font-mono text-slate-400 mb-8">
			{headline}
		</p>
		{description && (
			<p class="text-base md:text-lg text-slate-500 mb-12 max-w-2xl mx-auto leading-relaxed">
				{description}
			</p>
		)}
		<div class="flex flex-wrap gap-4 justify-center">
			<a
				href="https://github.com"
				target="_blank"
				rel="noopener noreferrer"
				class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-slate-50 font-mono text-sm rounded transition"
			>
				GitHub
			</a>
			<a
				href="https://linkedin.com"
				target="_blank"
				rel="noopener noreferrer"
				class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-slate-50 font-mono text-sm rounded transition"
			>
				LinkedIn
			</a>
			<a
				href="mailto:theoeloy12@gmail.com"
				class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-slate-50 font-mono text-sm rounded transition"
			>
				Email
			</a>
		</div>
	</div>
</section>
