---
interface Props {
	name: string;
	headline: string;
	description?: string;
	availability?: string;
	cvHref: string;
}

const { name, headline, description, availability, cvHref } = Astro.props;
---

<section class="max-w-4xl mx-auto px-6 py-20 flex items-center justify-center min-h-[calc(100vh-180px)] relative">
	<div class="hero-glow" aria-hidden="true"></div>
	<div class="text-center relative z-10">
		{availability && (
			<p class="inline-block text-xs font-mono text-amber-400 border border-amber-500/40 bg-amber-500/10 px-3 py-1 rounded-full mb-6">
				{availability}
			</p>
		)}
		<h1 class="text-5xl md:text-6xl font-mono font-bold mb-4 text-slate-50">
			{name}
		</h1>
		<p class="text-xl md:text-2xl font-mono text-slate-400 mb-8">
			{headline}
		</p>
		{description && (
			<p class="text-base md:text-lg text-slate-500 mb-12 max-w-2xl mx-auto leading-relaxed">
				{description}
			</p>
		)}
		<div class="flex flex-wrap gap-4 justify-center">
			<a
				href={cvHref}
				download
				class="px-6 py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 font-mono text-sm font-semibold rounded transition"
			>
				CV ↓
			</a>
			<a
				href="https://github.com/TheoEloy"
				target="_blank"
				rel="noopener noreferrer"
				class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-slate-50 font-mono text-sm rounded transition"
			>
				GitHub
			</a>
			<a
				href="https://linkedin.com/in/theo-eloy"
				target="_blank"
				rel="noopener noreferrer"
				class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-slate-50 font-mono text-sm rounded transition"
			>
				LinkedIn
			</a>
			<a
				href="mailto:theoeloy12@gmail.com"
				class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-slate-50 font-mono text-sm rounded transition"
			>
				Email
			</a>
		</div>
	</div>
</section>

<style>
	.hero-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 70% 50% at 50% 40%, rgba(251, 191, 36, 0.20) 0%, transparent 70%);
		pointer-events: none;
	}
</style>
